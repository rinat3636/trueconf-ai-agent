# Application
DEBUG=true
SECRET_KEY=change-me-to-a-strong-secret-key

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# AI Tunnel API (https://aitunnel.ru)
AITUNNEL_API_KEY=sk-aitunnel-xxx
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1

# LLM Models
LLM_CHAT_MODEL=gpt-4.1-mini
LLM_ANALYSIS_MODEL=gpt-4.1-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# TrueConf Integration
TRUECONF_SERVER_URL=https://localhost
TRUECONF_CLIENT_ID=your_client_id_here
TRUECONF_CLIENT_SECRET=your_client_secret_here
TRUECONF_BOT_USER=bot_username
TRUECONF_BOT_PASSWORD=bot_password
TRUECONF_POLL_INTERVAL=3
TRUECONF_ENABLED=false
TRUECONF_VERIFY_SSL=false

# Knowledge Base
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
