# === Database ===
MYSQL_ROOT_PASSWORD=trueconf_root_pass
MYSQL_PASSWORD=trueconf_db_pass
DATABASE_URL=mysql+aiomysql://trueconf:trueconf_db_pass@mysql:3306/trueconf_agent

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Qdrant ===
QDRANT_URL=http://qdrant:6333

# === JWT ===
SECRET_KEY=change-me-to-random-64-char-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === LLM ===
GROQ_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.cheat-ai.shop/v1
LLM_PROVIDER=anthropic
LLM_CHAT_MODEL=claude-sonnet-4-20250514
LLM_EMBEDDING_MODEL=text-embedding-3-small

# === TrueConf Chatbot (WebSocket API) ===
# Create a dedicated user account on TrueConf Server for the bot
TRUECONF_SERVER_ADDRESS=192.168.1.158
TRUECONF_BOT_USERNAME=ai_bot
TRUECONF_BOT_PASSWORD=your-bot-password
TRUECONF_BOT_USE_HTTPS=false
TRUECONF_BOT_WEB_PORT=0

# === TrueConf REST API (admin/monitoring) ===
TRUECONF_API_URL=http://your-trueconf-server:4307
TRUECONF_CLIENT_ID=your-oauth-client-id
TRUECONF_CLIENT_SECRET=your-oauth-client-secret
TRUECONF_OAUTH_REDIRECT_URI=https://localhost/
TRUECONF_BOT_ID=

# === App ===
APP_NAME=TrueConf AI Agent
DEBUG=false
