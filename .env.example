# === Database ===
MYSQL_ROOT_PASSWORD=trueconf_root_pass
MYSQL_PASSWORD=trueconf_db_pass
DATABASE_URL=mysql+aiomysql://trueconf:trueconf_db_pass@mysql:3306/trueconf_agent

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Qdrant ===
QDRANT_URL=http://qdrant:6333

# === JWT ===
SECRET_KEY=change-me-to-random-64-char-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === LLM ===
GROQ_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
LLM_PROVIDER=groq
LLM_CHAT_MODEL=llama-3.3-70b-versatile
LLM_EMBEDDING_MODEL=text-embedding-3-small

# === TrueConf ===
TRUECONF_API_URL=http://your-trueconf-server
TRUECONF_CLIENT_ID=your-oauth-client-id
TRUECONF_CLIENT_SECRET=your-oauth-client-secret
TRUECONF_OAUTH_REDIRECT_URI=https://localhost/
TRUECONF_BOT_ID=

# === App ===
APP_NAME=TrueConf AI Agent
DEBUG=false
